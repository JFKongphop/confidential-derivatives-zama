# Copy to .env.local and fill in your values

# Sepolia RPC (Infura, Alchemy, or public)
NEXT_PUBLIC_RPC_URL=

# Deployed contract addresses (fill in after `npx hardhat deploy --network sepolia`)
NEXT_PUBLIC_TOKEN_ADDRESS=
NEXT_PUBLIC_COLLATERAL_ADDRESS=
NEXT_PUBLIC_ORACLE_ADDRESS=
NEXT_PUBLIC_FUTURES_ADDRESS=
NEXT_PUBLIC_OPTIONS_ADDRESS=
NEXT_PUBLIC_POSITION_MANAGER_ADDRESS=

# (Optional) ERC-20 underlying for ConfidentialUSDCWrapper.
# If set, the wrap UI shows "Approve + Wrap ERC-20" instead of free test mint.
# Set SEPOLIA_USDC_ADDRESS in root .env too so the deploy script uses the wrapper.
NEXT_PUBLIC_UNDERLYING_ADDRESS=
